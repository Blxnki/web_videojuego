---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div id="particles-container"></div>

	<div id="loader" class="loader">
		<div class="loader-content">
			<div class="loader-ritual">
				<div class="pentagram-anim">
					<span class="p-star">★</span>
					<span class="p-circle"></span>
				</div>
			</div>
			<div class="loader-logo">
				<span class="loader-text">MIDNIGHT</span>
				<span class="loader-divider">♦</span>
				<span class="loader-text">OF VEIN</span>
			</div>
			<div class="loader-bar">
				<div class="loader-progress"></div>
				<div class="loader-glow"></div>
			</div>
			<div class="loader-info">
				<span class="loader-percent">0%</span>
				<span class="loader-status">CARGANDO SANGRE...</span>
			</div>
			<div class="loader-runes">
				<span>♱</span><span>☠</span><span>♦</span><span>⚔</span><span>♱</span>
			</div>
		</div>
		<div class="loader-ambient">
			<div class="ambient-orb"></div>
			<div class="ambient-orb"></div>
			<div class="ambient-orb"></div>
		</div>
	</div>

	<div id="cursor" class="cursor">
		<div class="cursor-trail">
			<span></span><span></span><span></span><span></span><span></span>
		</div>
		<div class="cursor-dot"></div>
		<div class="cursor-ring"></div>
	</div>

	<header class="header">
		<div class="header-bg"></div>
		<div class="logo">
			<span class="logo-text">MIDNIGHT</span>
			<span class="logo-text">OF VEIN</span>
		</div>
		<nav class="nav">
			<a href="#hero" class="nav-link" data-hover>INICIO</a>
			<a href="#story" class="nav-link" data-hover>HISTORIA</a>
			<a href="#features" class="nav-link" data-hover>CARACTERÍSTICAS</a>
			<a href="#classes" class="nav-link" data-hover>CLASES</a>
			<a href="#media" class="nav-link" data-hover>MEDIA</a>
		</nav>
		<div class="nav-decoration">
			<span class="deco-dot"></span>
		</div>
	</header>

	<section id="hero" class="hero">
		<div class="parallax-bg">
			<div class="parallax-layer layer-1" data-speed="0.1"></div>
			<div class="parallax-layer layer-2" data-speed="0.2"></div>
			<div class="parallax-layer layer-3" data-speed="0.3"></div>
			<div class="parallax-layer layer-4" data-speed="0.5"></div>
			<div class="parallax-layer layer-5" data-speed="0.8"></div>
		</div>
		<div class="hero-bg">
			<div class="orb orb-1"></div>
			<div class="orb orb-2"></div>
			<div class="orb orb-3"></div>
			<div class="orb orb-4"></div>
			<div class="grid-lines"></div>
			<div class="hero-vignette"></div>
		</div>
		
		<div class="hero-elements">
			<div class="floating-runes">
				<span class="f-rune" data-speed="1">♱</span>
				<span class="f-rune" data-speed="1.5">☠</span>
				<span class="f-rune" data-speed="0.8">♦</span>
				<span class="f-rune" data-speed="1.2">⚔</span>
				<span class="f-rune" data-speed="0.6">♱</span>
			</div>
			<div class="floating-particles">
				<span class="p-particle"></span>
				<span class="p-particle"></span>
				<span class="p-particle"></span>
				<span class="p-particle"></span>
				<span class="p-particle"></span>
			</div>
		</div>

		<div class="hero-content">
			<div class="hero-badge" data-anim="badge">
				<span class="badge-icon">✦</span>
				<span>UNA NUEVA LEYENDA EMPIEZA</span>
			</div>
			<h1 class="title" data-anim="title">
				<span class="title-word word-1">MIDNIGHT</span>
				<span class="title-word word-2">OF</span>
				<span class="title-word word-3">VEIN</span>
			</h1>
			<p class="subtitle" data-anim="subtitle">DESCIENDE A LA OSCURIDAD</p>
			<div class="hero-buttons" data-anim="buttons">
				<a href="/descargar" class="btn btn-primary" data-hover>
					<span class="btn-bg"></span>
					<span class="btn-text">DESCARGAR</span>
					<span class="btn-glow"></span>
				</a>
				<button class="btn btn-secondary" data-hover>
					<span class="btn-text">VER TRAILER</span>
					<span class="btn-border"></span>
				</button>
			</div>
			<div class="hero-stats" data-anim="stats">
				<div class="stat">
					<span class="stat-num">16+</span>
					<span class="stat-label">EDAD</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">2026</span>
					<span class="stat-label">LANZAMIENTO</span>
				</div>
			</div>
		</div>
	</section>

	<section id="story" class="story">
		<div class="story-bg">
			<div class="fog-layer fog-1"></div>
			<div class="fog-layer fog-2"></div>
			<div class="fog-layer fog-3"></div>
			<div class="blood-drops">
				<span class="b-drop"></span><span class="b-drop"></span>
				<span class="b-drop"></span><span class="b-drop"></span>
				<span class="b-drop"></span>
			</div>
		</div>
		
		<div class="section-content">
			<div class="section-header" data-anim="header">
				<span class="section-tag">
					<span class="tag-icon">///</span>
					Historia
				</span>
				<h2 class="section-title">Una nueva aventura</h2>
				<div class="title-line"></div>
			</div>
			
			<div class="story-grid">
				<div class="story-visual" data-anim="visual">
					<div class="ritual-circle">
						<div class="r-ring r-1"></div>
						<div class="r-ring r-2"></div>
						<div class="r-ring r-3"></div>
						<div class="r-center">
							<span class="r-icon">♱</span>
						</div>
					</div>
				</div>
				
				<div class="story-texts">
					<p class="story-text" data-anim="text" data-delay="0">
						Vein lleva siglos haciendo lo que le apetecía, sin que nadie le pong límites ni le cobre facturas. Lástima que descubriera que el verdadero peligro no era el ajo, el sol ni los cazadores con estacas… eran las mesas de juego, las fichas prestadas y la compañía nocturna de dudosa reputación.
					</p>
					<p class="story-text" data-anim="text" data-delay="1">
						Entre una racha de mala suerte y otra de malas decisiones, cometió el error de deberle una pequeña fortuna al capo más peligroso de Volvania City. Spoiler: la mafia no acepta "te lo pago la semana que viene".
					</p>
					<p class="story-text" data-anim="text" data-delay="2">
						No hubo carta de cobro. Solo un golpe en la nuca, un saco en la cabeza y un despertar en una celda sin ventanas que huele a miedo y a lejía barata. Ya no le deben respeto. Le deben la cabeza.
					</p>
					<p class="story-text highlight" data-anim="text" data-delay="3">
						Pero Vein es vampiro, y lleva eones practicando el arte de colarse donde no le invitan y salir antes de que cierren la puerta. Ahora su misión es simple: escapar. Sin poderes ilimitados, sin reservas de sangre y con una adicción que, irónicamente, le ha metido en este lío.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section id="features" class="features">
		<div class="features-bg">
			<div class="hex-pattern"></div>
			<div class="energy-lines">
				<span></span><span></span><span></span>
			</div>
		</div>

		<div class="section-content">
			<div class="section-header" data-anim="header">
				<span class="section-tag">
					<span class="tag-icon">///</span>
					¿podras escapar?
				</span>
				<h2 class="section-title">Personajes</h2>
				<div class="title-line"></div>
			</div>

			<div class="features-grid">
				<div class="feature-card" data-anim="card" data-delay="0" data-hover>
					<div class="card-glow"></div>
					<div class="card-border">
						<span class="c-corner tl"></span>
						<span class="c-corner tr"></span>
						<span class="c-corner bl"></span>
						<span class="c-corner br"></span>
					</div>
					<div class="card-icon">
						<span class="icon-inner">☠</span>
					</div>
					<h3>COMBATE SANGRIENTO</h3>
					<p>Sistema de combate estratégico con múltiples armas cuerpo a cuerpo y magia oscura. Cada golpe cuenta.</p>
					<div class="card-particles">
						<span></span><span></span><span></span>
					</div>
				</div>

				<div class="feature-card" data-anim="card" data-delay="1" data-hover>
					<div class="card-glow"></div>
					<div class="card-border">
						<span class="c-corner tl"></span>
						<span class="c-corner tr"></span>
						<span class="c-corner bl"></span>
						<span class="c-corner br"></span>
					</div>
					<div class="card-icon">
						<span class="icon-inner">♦</span>
					</div>
					<h3>ARBOL DE HABILIDADES</h3>
					<p>Desarrolla tu vampiro: Clan de los No Muertos, Nigromancia o Coleccionista de Sangre. Tu destino es tuyo.</p>
					<div class="card-particles">
						<span></span><span></span><span></span>
					</div>
				</div>

				<div class="feature-card" data-anim="card" data-delay="2" data-hover>
					<div class="card-glow"></div>
					<div class="card-border">
						<span class="c-corner tl"></span>
						<span class="c-corner tr"></span>
						<span class="c-corner bl"></span>
						<span class="c-corner br"></span>
					</div>
					<div class="card-icon">
						<span class="icon-inner">♱</span>
					</div>
					<h3>MUNDO ABIERTO</h3>
					<p>Explora Victorian Gothic City, desde callejones obscenos hasta mansiones aristocráticas. Cada rincón tiene secretos.</p>
					<div class="card-particles">
						<span></span><span></span><span></span>
					</div>
				</div>

				<div class="feature-card" data-anim="card" data-delay="3" data-hover>
					<div class="card-glow"></div>
					<div class="card-border">
						<span class="c-corner tl"></span>
						<span class="c-corner tr"></span>
						<span class="c-corner bl"></span>
						<span class="c-corner br"></span>
					</div>
					<div class="card-icon">
						<span class="icon-inner">⚔</span>
					</div>
					<h3>MULTIJUGADOR</h3>
					<p>Alianzas temporales o guerras de clans. Elige tu bando en la guerra vampiresca. La sangre nunca perdona.</p>
					<div class="card-particles">
						<span></span><span></span><span></span>
					</div>
				</div>
			</div>
		</div>
	</section>

	
	<footer class="footer">
		<div class="footer-bg">
			<div class="footer-grid"></div>
			<div class="footer-gradient"></div>
		</div>
		
		<div class="footer-content">
			<div class="footer-main" data-anim="footer">
				<div class="footer-logo">
					<span class="fl-icon">🦇</span>
					<span class="fl-text">MIDNIGHT</span>
					<span class="fl-divider">♦</span>
					<span class="fl-text">OF VEIN</span>
				</div>
				<p class="footer-tagline">LA OSCURIDAD TE ESPERA</p>
			</div>

			<div class="footer-links" data-anim="footer" data-delay="1">
				<a href="#" data-hover>DISCORD</a>
				<span class="link-divider">//</span>
				<a href="#" data-hover>TWITTER</a>
				<span class="link-divider">//</span>
				<a href="#" data-hover>YOUTUBE</a>
				<span class="link-divider">//</span>
				<a href="#" data-hover>INSTAGRAM</a>
			</div>

			<div class="footer-bottom">
				<p class="footer-copy">© 2026 NIGHTFALL STUDIOS. TODOS LOS DERECHOS RESERVADOS.</p>
				<div class="footer-runes">
					<span>♱</span><span>☠</span><span>♦</span><span>⚔</span><span>♱</span>
				</div>
			</div>
		</div>
	</footer>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const particlesContainer = document.getElementById('particles-container');
	const loader = document.getElementById('loader');
	const cursor = document.getElementById('cursor');

	// ============ PARTICLE SYSTEM ============
	class ParticleSystem {
		constructor() {
			this.particles = [];
			this.bloodDrops = [];
			this.magicSparkles = [];
			this.init();
		}

		init() {
			this.createBloodDrops();
			this.createMagicSparkles();
			this.createAmbientParticles();
		}

		createBloodDrops() {
			for (let i = 0; i < 15; i++) {
				const drop = document.createElement('div');
				drop.className = 'global-blood-drop';
				drop.innerHTML = '<span class="drop-shape"></span>';
				
				const startX = Math.random() * window.innerWidth;
				const duration = 8 + Math.random() * 8;
				const delay = Math.random() * 10;
				
				drop.style.cssText = `
					left: ${startX}px;
					top: -50px;
					animation: bloodDrop ${duration}s linear ${delay}s infinite;
				`;
				
				particlesContainer?.appendChild(drop);
			}
		}

		createMagicSparkles() {
			for (let i = 0; i < 30; i++) {
				const sparkle = document.createElement('div');
				sparkle.className = 'global-sparkle';
				sparkle.innerHTML = '<span class="sparkle-shape"></span>';
				
				const startX = Math.random() * window.innerWidth;
				const startY = Math.random() * window.innerHeight;
				const size = 2 + Math.random() * 4;
				const duration = 2 + Math.random() * 3;
				
				sparkle.style.cssText = `
					left: ${startX}px;
					top: ${startY}px;
					width: ${size}px;
					height: ${size}px;
					animation: sparklePulse ${duration}s ease-in-out ${Math.random() * 5}s infinite;
				`;
				
				particlesContainer?.appendChild(sparkle);
			}
		}

		createAmbientParticles() {
			for (let i = 0; i < 20; i++) {
				const particle = document.createElement('div');
				particle.className = 'global-ambient-particle';
				
				const x = Math.random() * window.innerWidth;
				const y = Math.random() * window.innerHeight;
				const size = 1 + Math.random() * 3;
				const duration = 15 + Math.random() * 20;
				
				particle.style.cssText = `
					left: ${x}px;
					top: ${y}px;
					width: ${size}px;
					height: ${size}px;
					animation: ambientFloat ${duration}s linear infinite;
				`;
				
				particlesContainer?.appendChild(particle);
			}
		}
	}

	// ============ LOADER ============
	let progress = 0;
	const statusTexts = [
		'CARGANDO SANGRE...',
		'CONECTANDO VENAS...',
		'INYECTANDO OSCURIDAD...',
		'DESPERTANDO NO MUERTO...',
		'PREPARANDO CAZA...',
		'LISTO PARA CAZAR...'
	];

	const loaderProgress = document.querySelector('.loader-progress');
	const loaderPercent = document.querySelector('.loader-percent');
	const loaderStatus = document.querySelector('.loader-status');

	function updateLoader() {
		if (progress < 100) {
			progress += Math.random() * 12 + 3;
			if (progress > 100) progress = 100;
			
			(loaderProgress as HTMLElement).style.width = `${progress}%`;
			(loaderPercent as HTMLElement).textContent = `${Math.floor(progress)}%`;
			
			const statusIndex = Math.floor((progress / 100) * (statusTexts.length - 1));
			(loaderStatus as HTMLElement).textContent = statusTexts[statusIndex];
			
			setTimeout(updateLoader, 100);
		} else {
			setTimeout(hideLoader, 600);
		}
	}

	function hideLoader() {
		const tl = gsap.timeline();
		
		tl.to('.loader-runes span', {
			opacity: 0,
			duration: 0.3,
			stagger: 0.05
		})
		.to('.loader-info', {
			opacity: 0,
			duration: 0.4
		}, '-=0.2')
		.to('.loader-logo', {
			scale: 1.2,
			opacity: 0,
			duration: 0.5,
			ease: 'power2.in'
		})
		.to('.loader-ritual', {
			scale: 2,
			opacity: 0,
			duration: 0.6,
			ease: 'power2.in'
		}, '-=0.3')
		.to(loader, {
			opacity: 0,
			duration: 0.5,
			onComplete: () => {
				loader?.remove();
				new ParticleSystem();
				initAnimations();
			}
		});
	}

	// ============ MAIN ANIMATIONS ============
	function initAnimations() {
		// Header
		gsap.from('.header', {
			y: -100,
			opacity: 0,
			duration: 1.2,
			ease: 'power4.out'
		});

		gsap.from('.logo-icon', {
			scale: 0,
			rotation: -180,
			duration: 1,
			ease: 'elastic.out(1, 0.5)',
			delay: 0.3
		});

		gsap.from('.nav-link', {
			y: -20,
			opacity: 0,
			duration: 0.6,
			stagger: 0.1,
			delay: 0.5,
			ease: 'power3.out'
		});

		// Hero animations
		const heroTl = gsap.timeline();

		heroTl.from('.hero-badge', {
			scale: 0,
			opacity: 0,
			duration: 0.8,
			ease: 'back.out(1.7)'
		})
		.from('.title-word', {
			y: 100,
			opacity: 0,
			duration: 1,
			stagger: 0.15,
			ease: 'power4.out'
		}, '-=0.4')
		.from('.subtitle', {
			y: 30,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		}, '-=0.5')
		.from('.hero-buttons', {
			y: 30,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		}, '-=0.4')
		.from('.hero-stats', {
			y: 20,
			opacity: 0,
			duration: 0.6,
			ease: 'power3.out'
		}, '-=0.3')
		.from('.scroll-indicator', {
			opacity: 0,
			duration: 0.5
		}, '-=0.2');

		// Floating runes animation
		gsap.utils.toArray('.f-rune').forEach((rune: any, i: number) => {
			const speed = parseFloat(rune.dataset.speed) || 1;
			gsap.to(rune, {
				y: `random(-30, 30)`,
				x: `random(-20, 20)`,
				rotation: `random(-15, 15)`,
				duration: 3 * speed,
				repeat: -1,
				yoyo: true,
				ease: 'sine.inOut',
				delay: i * 0.3
			});
		});

		// Orb animations
		gsap.to('.orb-1', {
			x: '30vw',
			y: '20vh',
			duration: 12,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut'
		});

		gsap.to('.orb-2', {
			x: '-25vw',
			y: '-30vh',
			duration: 15,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut'
		});

		gsap.to('.orb-3', {
			x: '-15vw',
			y: '25vh',
			duration: 10,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut'
		});

		gsap.to('.orb-4', {
			scale: '1.5',
			duration: 8,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut'
		});

		// Scroll indicator animation
		gsap.to('.mouse-wheel', {
			y: 8,
			duration: 1,
			repeat: -1,
			yoyo: true,
			ease: 'power2.inOut'
		});

		// Section headers animation
		gsap.utils.toArray('[data-anim="header"]').forEach((header: any) => {
			gsap.from(header, {
				scrollTrigger: {
					trigger: header,
					start: 'top 80%',
				},
				y: 60,
				opacity: 0,
				duration: 1,
				ease: 'power3.out'
			});
		});

		// Story text animations
		gsap.utils.toArray('[data-anim="text"]').forEach((text: any, i: number) => {
			const delay = parseFloat(text.dataset.delay) || 0;
			gsap.from(text, {
				scrollTrigger: {
					trigger: text,
					start: 'top 85%',
				},
				y: 40,
				opacity: 0,
				duration: 1,
				ease: 'power3.out',
				delay: delay * 0.3
			});
		});

		// Ritual circle rotation
		gsap.to('.r-ring', {
			scrollTrigger: {
				trigger: '.story-visual',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1
			},
			rotation: 360,
			stagger: 0.2
		});

		// Blood drops on scroll
		gsap.utils.toArray('.b-drop').forEach((drop: any, i: number) => {
			gsap.to(drop, {
				scrollTrigger: {
					trigger: '.story',
					start: 'top bottom',
					end: 'bottom top',
					scrub: 1
				},
				y: 300 + i * 50,
				opacity: 0,
				delay: i * 0.1
			});
		});

		// Fog animation
		gsap.to('.fog-1', {
			scrollTrigger: {
				trigger: '.story',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1
			},
			x: '-30%',
			duration: 10
		});

		gsap.to('.fog-2', {
			scrollTrigger: {
				trigger: '.story',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1
			},
			x: '30%',
			duration: 15
		});

		// Feature cards
		gsap.utils.toArray('[data-anim="card"]').forEach((card: any, i: number) => {
			const delay = parseFloat(card.dataset.delay) || 0;
			gsap.from(card, {
				scrollTrigger: {
					trigger: card,
					start: 'top 85%',
				},
				y: 80,
				opacity: 0,
				duration: 0.8,
				ease: 'power3.out',
				delay: delay * 0.2
			});
		});

		// Card hover effects
		document.querySelectorAll('.feature-card').forEach((card: any) => {
			card.addEventListener('mouseenter', () => {
				gsap.to(card, {
					y: -15,
					duration: 0.4,
					ease: 'power2.out'
				});
				gsap.to(card.querySelector('.card-glow'), {
					opacity: 0.2,
					duration: 0.4
				});
				gsap.to(card.querySelectorAll('.card-particles span'), {
					opacity: 1,
					y: 0,
					duration: 0.4,
					stagger: 0.1
				});
			});
			card.addEventListener('mouseleave', () => {
				gsap.to(card, {
					y: 0,
					duration: 0.4,
					ease: 'power2.out'
				});
				gsap.to(card.querySelector('.card-glow'), {
					opacity: 0,
					duration: 0.4
				});
				gsap.to(card.querySelectorAll('.card-particles span'), {
					opacity: 0,
					y: -10,
					duration: 0.3
				});
			});
		});

		// Class cards
		gsap.utils.toArray('[data-anim="class"]').forEach((card: any, i: number) => {
			const delay = parseFloat(card.dataset.delay) || 0;
			gsap.from(card, {
				scrollTrigger: {
					trigger: card,
					start: 'top 85%',
				},
				x: i % 2 === 0 ? -80 : 80,
				opacity: 0,
				duration: 1,
				ease: 'power3.out',
				delay: delay * 0.2
			});
		});

		// Stat bars animation
		gsap.utils.toArray('.sb-progress').forEach((bar: any) => {
			const width = bar.style.width;
			bar.style.width = '0';
			gsap.to(bar, {
				scrollTrigger: {
					trigger: bar,
					start: 'top 80%',
				},
				width: width,
				duration: 1.5,
				ease: 'power2.out'
			});
		});

		// Media items
		gsap.utils.toArray('[data-anim="media"]').forEach((item: any, i: number) => {
			const delay = parseFloat(item.dataset.delay) || 0;
			gsap.from(item, {
				scrollTrigger: {
					trigger: item,
					start: 'top 90%',
				},
				scale: 0.8,
				opacity: 0,
				duration: 0.8,
				ease: 'power3.out',
				delay: delay * 0.2
			});
		});

		// Media hover
		document.querySelectorAll('.media-item').forEach((item: any) => {
			item.addEventListener('mouseenter', () => {
				gsap.to(item, {
					scale: 1.03,
					duration: 0.3,
					ease: 'power2.out'
				});
			});
			item.addEventListener('mouseleave', () => {
				gsap.to(item, {
					scale: 1,
					duration: 0.3,
					ease: 'power2.out'
				});
			});
		});

		// Footer animation
		gsap.utils.toArray('[data-anim="footer"]').forEach((el: any, i: number) => {
			const delay = parseFloat(el.dataset.delay) || 0;
			gsap.from(el, {
				scrollTrigger: {
					trigger: '.footer',
					start: 'top 85%',
				},
				y: 30,
				opacity: 0,
				duration: 0.8,
				ease: 'power3.out',
				delay: delay * 0.3
			});
		});

		// Parallax effects with ScrollTrigger
		gsap.to('.parallax-layer', {
			scrollTrigger: {
				trigger: '.hero',
				start: 'top top',
				end: 'bottom top',
				scrub: 1
			},
			y: (i, el) => {
				const speed = parseFloat(el.dataset.speed) || 0.1;
				return 200 * speed;
			}
		});

		// Story section parallax
		gsap.to('.story-bg .fog-layer', {
			scrollTrigger: {
				trigger: '.story',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 2
			},
			x: (i) => (i + 1) * 100,
			y: -50
		});

		// Features section parallax
		gsap.to('.hex-pattern', {
			scrollTrigger: {
				trigger: '.features',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1
			},
			backgroundPosition: '0 100px'
		});

		gsap.to('.class-glow', {
			scrollTrigger: {
				trigger: '.classes',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1.5
			},
			x: (i) => (i - 1) * 150,
			y: (i) => (i - 1) * 100
		});

		gsap.to('.orb', {
			scrollTrigger: {
				trigger: '.hero',
				start: 'top top',
				end: 'bottom top',
				scrub: 1
			},
			y: 200
		});

		// Energy lines animation
		gsap.to('.energy-lines span', {
			scrollTrigger: {
				trigger: '.features',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1
			},
			x: '100%',
			stagger: 0.2
		});
	}

	// ============ PARALLAX BACKGROUND ============
	function initParallax() {
		const layers = document.querySelectorAll('.parallax-layer');
		
		document.addEventListener('mousemove', (e) => {
			const x = (e.clientX / window.innerWidth - 0.5) * 2;
			const y = (e.clientY / window.innerHeight - 0.5) * 2;
			
			layers.forEach((layer: any) => {
				const speed = parseFloat(layer.dataset.speed) || 0.1;
				gsap.to(layer, {
					x: x * 50 * speed,
					y: y * 30 * speed,
					duration: 1,
					ease: 'power2.out'
				});
			});
		});
	}

	// ============ SCREEN SHAKE ============
	function screenShake(intensity = 10, duration = 0.3) {
		const body = document.body;
		gsap.to(body, {
			x: `random(-${intensity}, ${intensity})`,
			y: `random(-${intensity}, ${intensity})`,
			duration: duration / 10,
			repeat: 5,
			yoyo: true,
			ease: 'none',
			onComplete: () => {
				gsap.to(body, { x: 0, y: 0, duration: 0.1 });
			}
		});
	}

	// ============ GLOW EFFECTS ============
	function initGlowEffects() {
		document.querySelectorAll('[data-hover]').forEach((el: any) => {
			el.addEventListener('mouseenter', () => {
				gsap.to(el, {
					boxShadow: '0 0 30px rgba(139, 92, 246, 0.5), 0 0 60px rgba(220, 38, 38, 0.3)',
					duration: 0.3,
					ease: 'power2.out'
				});
			});
			el.addEventListener('mouseleave', () => {
				gsap.to(el, {
					boxShadow: 'none',
					duration: 0.3,
					ease: 'power2.out'
				});
			});
		});
	}

	// ============ CLICK EFFECT (without shake) ============
	function initClickEffect() {
		const clickableElements = document.querySelectorAll('a, button, .feature-card, .class-card, .media-item, .nav-link');
		
		clickableElements.forEach((el: any) => {
			el.addEventListener('click', () => {
				gsap.to(el, {
					scale: 0.95,
					duration: 0.1,
					yoyo: true,
					repeat: 1
				});
			});
		});
	}

	// Cursor hover effects
	document.querySelectorAll('[data-hover]').forEach((el: any) => {
		el.addEventListener('mouseenter', () => {
			const ring = cursor?.querySelector('.cursor-ring');
			const dot = cursor?.querySelector('.cursor-dot');
			gsap.to(ring, { scale: 2, duration: 0.3 });
			gsap.to(dot, { scale: 2, duration: 0.3 });
		});
		el.addEventListener('mouseleave', () => {
			const ring = cursor?.querySelector('.cursor-ring');
			const dot = cursor?.querySelector('.cursor-dot');
			gsap.to(ring, { scale: 1, duration: 0.3 });
			gsap.to(dot, { scale: 1, duration: 0.3 });
		});
	});

	// ============ CURSOR ============
	document.addEventListener('mousemove', (e) => {
		const dot = cursor?.querySelector('.cursor-dot');
		const ring = cursor?.querySelector('.cursor-ring');
		const trails = cursor?.querySelectorAll('.cursor-trail span');

		if (dot) gsap.to(dot, { x: e.clientX, y: e.clientY, duration: 0 });
		if (ring) gsap.to(ring, { x: e.clientX, y: e.clientY, duration: 0.3, ease: 'power2.out' });

		trails?.forEach((trail: any, i: number) => {
			gsap.to(trail, {
				x: e.clientX,
				y: e.clientY,
				duration: 0.5 + i * 0.1,
				ease: 'power2.out'
			});
		});
	});

	// Cursor hover effects
	document.querySelectorAll('[data-hover]').forEach((el: any) => {
		el.addEventListener('mouseenter', () => {
			const ring = cursor?.querySelector('.cursor-ring');
			const dot = cursor?.querySelector('.cursor-dot');
			gsap.to(ring, { scale: 2, duration: 0.3 });
			gsap.to(dot, { scale: 2, duration: 0.3 });
		});
		el.addEventListener('mouseleave', () => {
			const ring = cursor?.querySelector('.cursor-ring');
			const dot = cursor?.querySelector('.cursor-dot');
			gsap.to(ring, { scale: 1, duration: 0.3 });
			gsap.to(dot, { scale: 1, duration: 0.3 });
		});
	});

	// ============ START LOADER ============
	updateLoader();

	// ============ INIT ALL EFFECTS ============
	initParallax();
	initGlowEffects();
	initClickEffect();

	// ============ ADDITIONAL EFFECTS ============
	// Glitch effect on title words
	gsap.to('.title-word', {
		scrollTrigger: {
			trigger: '.hero',
			start: 'top top',
			end: 'bottom top',
			scrub: 1
		},
		skewX: 10,
		ease: 'none'
	});

	// Add subtle shake on hover for buttons
	document.querySelectorAll('.btn').forEach((btn: any) => {
		btn.addEventListener('mouseenter', () => {
			gsap.to(btn, {
				x: 'random(-2, 2)',
				duration: 0.1,
				repeat: -1,
				yoyo: true
			});
		});
		btn.addEventListener('mouseleave', () => {
			gsap.killTweensOf(btn, 'x');
			gsap.to(btn, { x: 0, duration: 0.2 });
		});
	});
</script>

