	.class-desc {
		font-size: 0.85rem;
		color: #737373;
		line-height: 1.6;
		margin-bottom: 20px;
	}

	.class-stats {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.stat-bar {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.sb-label {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.55rem;
		letter-spacing: 2px;
		color: #52525b;
		width: 80px;
	}

	.sb-fill {
		flex: 1;
		height: 6px;
		background: #27272a;
		border-radius: 3px;
		overflow: hidden;
	}

	.sb-progress {
		height: 100%;
		background: linear-gradient(90deg, #8b5cf6, #dc2626);
		border-radius: 3px;
		transition: width 1.5s ease-out;
	}

	/* ============ MEDIA ============ */
	.media {
		min-height: 80vh;
		padding: 150px 0;
		position: relative;
		overflow: hidden;
	}

	.media-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: #0a0a0a;
	}

	.media-scanlines {
		position: absolute;
		width: 100%;
		height: 100%;
		background: repeating-linear-gradient(
			0deg,
			transparent,
			transparent 2px,
			rgba(0, 0, 0, 0.1) 2px,
			rgba(0, 0, 0, 0.1) 4px
		);
		opacity: 0.5;
	}

